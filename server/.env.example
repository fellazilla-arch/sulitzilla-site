# Copy to .env and fill in. Never commit .env.
GRIST_API_KEY=your_grist_api_key
GRIST_DOC_ID=eEMaR9RHiD3ruspeNWqKHn
GRIST_TABLE=Master_List
# GRIST_BASE=https://grist.sulitzilla.com/api

# Daily auto-sync time (server clock via timezone; runs on the deployed host, not your laptop).
GRIST_SYNC_TIMEZONE=Asia/Manila
GRIST_SYNC_HOUR=18
GRIST_SYNC_MINUTE=0

# Secret for manual sync (bookmark /api/admin/sync?key=… or use ?refresh=1&key=… on the price list).
GRIST_SYNC_SECRET=change_me_to_a_long_random_string
